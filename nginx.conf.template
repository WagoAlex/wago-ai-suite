server {
    listen 80;
    server_name  $SERVER_NAME;
    return 301 https://$host$request_uri; # Redirect HTTP to HTTPS
}
	
server {
    listen 443 ssl;
    server_name $SERVER_NAME;
    error_log /var/log/nginx/error.log warn;
    access_log /var/log/nginx/access.log;

    ssl_verify_client off;
    ssl_certificate /etc/ssl/nginx/selfsigned.crt;
    ssl_certificate_key /etc/ssl/nginx/selfsigned.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    # Global settings for Label Studio
    proxy_connect_timeout 300s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;
    proxy_buffer_size 64k;
    proxy_buffers 32 64k;
    proxy_busy_buffers_size 128k;

    # ===== LABEL STUDIO CONFIGURATION =====
# ===== LABEL STUDIO CONFIGURATION =====
# Reihenfolge ist KRITISCH - spezifischere Pfade zuerst!

# 1. Label Studio Static Files - HÖCHSTE PRIORITÄT
location ~ ^/labelstudio/static/(.*)$ {
    # Direkte Weiterleitung ohne trailing slash issues
    proxy_pass http://wago-label-studio:8080/static/$1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host $host;
    
    # KEINE Redirects für static files
    proxy_redirect off;
    
    # Caching für bessere Performance
    expires 1d;
    add_header Cache-Control "public, max-age=86400";
    
    # CORS für static files
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, HEAD, OPTIONS" always;
    
    # Debug logging
    access_log /var/log/nginx/labelstudio-static.log;
    error_log /var/log/nginx/labelstudio-static-error.log warn;
}

