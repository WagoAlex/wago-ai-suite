	location /n8n/ {
		# Basic proxy configuration 
		proxy_pass http://n8n:5678/; 
		
		# Headers
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header X-Forwarded-Host $host;
		
		# WebSocket support 
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		
		# Basic timeouts 
		proxy_read_timeout 3600s;
		proxy_send_timeout 3600s;
		proxy_connect_timeout 60s;
		
		# Payload size (PROVEN)
		client_max_body_size 50M;
		
		# Simple logging 
		access_log /var/log/nginx/n8n.log;
		error_log /var/log/nginx/n8n-error.log warn;
	}

	# ===== N8N WEBHOOKS (SEPARATE FOR PERFORMANCE) =====
	location /n8n/webhook/ {
		proxy_pass http://n8n:5678/webhook/;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection "upgrade";
		client_max_body_size 50M;
		proxy_read_timeout 300s;
		access_log /var/log/nginx/n8n-webhook.log;
	}

	# ===== N8N API (SEPARATE FOR SWAGGER ACCESS) =====
	location /n8n/api/ {
		proxy_pass http://n8n:5678/api/;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_read_timeout 300s;
		access_log /var/log/nginx/n8n-api.log;
	}

    # ===== REMOTE INFERENCE =====
    location /api/remote/ {
        proxy_pass http://$INFERENCE_URL:8042/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        access_log /var/log/nginx/remote.log;
        error_log /var/log/nginx/remote-error.log debug;
    }
	location /api/remote/video/ {
		proxy_pass http://$INFERENCE_URL:8042/video/;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_read_timeout 60s;
		proxy_buffering off;  
		access_log /var/log/nginx/video.log combined;
		error_log /var/log/nginx/video-error.log debug;
	}
	
	location / {
		root /usr/share/nginx/html;
		try_files $uri /index.html;
		index index.html index.htm;
	}

}